##############################################################################
#  Vidyaro Live Server — .env.example
#
#  Copy to .env and fill in real values before running locally.
#  In Coolify, set these in the UI — do NOT commit .env to git!
##############################################################################


# ── Nginx template variables ──────────────────────────────────────────────────
# Full URL of the Next.js RTMP auth endpoint
# nginx POSTs stream name + key here before allowing publish
STREAM_AUTH_URL=https://vidyaro.com/api/stream-auth

# Domain only (no https://) — used to construct hls_key_url in nginx.conf
VIDYARO_APP_DOMAIN=vidyaro.com


# ── Next.js application ───────────────────────────────────────────────────────
# Base URL of your deployed Next.js app (for recorder.sh webhook)
VIDYARO_APP_URL=https://vidyaro.com

# Shared secret — must match INTERNAL_SECRET in your Next.js env
# IMPORTANT: Generate ONLY with: openssl rand -hex 32
# Do NOT use base64 — the + / = characters break the nginx map block key
INTERNAL_SECRET=CHANGE_ME_openssl_rand_hex_32


# ── Cloudflare R2 (S3-compatible storage) ─────────────────────────────────────
# Find in: Cloudflare Dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=vidyaro-recordings

# Public base URL for the bucket (custom domain or r2.dev subdomain)
R2_PUBLIC_URL=https://recordings.vidyaro.com


# ── Appwrite ──────────────────────────────────────────────────────────────────
# recorder.sh uses these to resolve lectureId from roomId
# FIX: Only databases.read permission is needed — NOT databases.write
# Granting write was over-permissioned and a security risk
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_server_api_key_with_databases_READ_permission
APPWRITE_DATABASE_ID=your_database_id
APPWRITE_STREAM_KEYS_COLLECTION_ID=stream_keys
